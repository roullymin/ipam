upstream django_backend {
    server backend:8000;
}

server {
    listen 80;
    server_name localhost; # 生产环境请修改为你的域名或 IP

    # 强制跳转 HTTPS (建议在 SSL 证书配置好后取消注释)
    # return 301 https://$host$request_uri;

    # --- 前端 React 静态文件 ---
    location / {
        root /usr/share/nginx/html;
        index index.html index.htm;
        try_files $uri $uri/ /index.html; # React 路由支持
    }

    # --- Django 静态资源 (CSS/JS) ---
    location /static/ {
        alias /app/static/;
        expires 7d;
        access_log off;
    }

    # --- Django 媒体资源 (用户上传) ---
    location /media/ {
        alias /app/media/;
    }

    # --- 后端 API 反向代理 ---
    location /api/ {
        proxy_pass http://django_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # 允许大文件上传 (如导入 Excel)
        client_max_body_size 50M;
    }

    # --- Django Admin 后台 ---
    location /admin/ {
        proxy_pass http://django_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# --- HTTPS 配置示例 (配置好证书后取消注释) ---
