import React, { useState, useEffect, useMemo, useRef, useCallback } from 'react';
import {
  Server, ShieldCheck, Search, RefreshCw, Folder, Network,
  ChevronRight, ChevronDown, Edit2, Trash2,
  X, Save, LogOut, LayoutGrid, Plus, Upload, Download,
  MapPin, Box, Shield, Activity, Users, Database, Settings,
  AlertTriangle, Grid as GridIcon, List as ListIcon, Loader2, ArrowLeftRight, Zap, Calculator, HardDrive, AlignLeft,
  ZoomIn, ZoomOut, Maximize, Image as ImageIcon, FileText, Terminal,
  AlignJustify, Columns, Code
} from 'lucide-react';

// ============================================================================
// 工具函数：安全整数解析
// ============================================================================
const safeInt = (val, def = 0) => {
    const parsed = parseInt(val, 10);
    return isNaN(parsed) ? def : parsed;
};

// ============================================================================
// 补全缺失组件：RackModal (机柜编辑)
// ============================================================================
const RackModal = ({ rack, onClose, onSave, locations, initialDatacenter }) => {
    const [formData, setFormData] = useState({
        name: '', code: '', height: 42, datacenter: initialDatacenter || '',
        pdu_a_power: 0, pdu_b_power: 0, ...rack
    });

    const handleSubmit = () => {
        if (!formData.name || !formData.code) return alert('名称和编号必填');
        onSave(formData);
    };

    return (
        <Modal isOpen={true} onClose={onClose} title={rack ? '编辑机柜' : '新增机柜'}>
            <div className="space-y-4">
                <FormInput label="机柜名称" value={formData.name} onChange={e => setFormData({...formData, name: e.target.value})} required placeholder="例如: 业务机柜01" />
                <FormInput label="机柜编号" value={formData.code} onChange={e => setFormData({...formData, code: e.target.value})} required placeholder="A01" />
                <div className="grid grid-cols-2 gap-4">
                    <FormInput label="高度 (U)" type="number" value={formData.height} onChange={e => setFormData({...formData, height: safeInt(e.target.value)})} required />
                    <div className="mb-4 relative">
                        <label className="block text-xs font-semibold text-slate-500 mb-1.5 uppercase">所属机房</label>
                        <div className="relative">
                            <select value={formData.datacenter} onChange={e => setFormData({...formData, datacenter: e.target.value})} className="w-full bg-white border border-slate-300 rounded-md px-3 py-2 text-sm outline-none appearance-none">
                                <option value="">选择机房...</option>
                                {locations.map(l => <option key={l.id} value={l.id}>{l.name}</option>)}
                            </select>
                            <div className="absolute right-2.5 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400"><ChevronDown className="w-4 h-4" /></div>
                        </div>
                    </div>
                </div>
                 <div className="bg-slate-50 p-3 rounded border border-slate-200">
                    <label className="block text-xs font-bold text-slate-500 mb-2 uppercase">PDU 实测读数 (W)</label>
                    <div className="grid grid-cols-2 gap-4">
                         <FormInput label="A路功耗" type="number" value={formData.pdu_a_power} onChange={e => setFormData({...formData, pdu_a_power: safeInt(e.target.value)})} />
                         <FormInput label="B路功耗" type="number" value={formData.pdu_b_power} onChange={e => setFormData({...formData, pdu_b_power: safeInt(e.target.value)})} />
                    </div>
                </div>
                <div className="flex justify-end pt-4">
                    <button onClick={handleSubmit} className="px-6 py-2 bg-blue-600 text-white rounded font-bold shadow-lg hover:bg-blue-700">保存</button>
                </div>
            </div>
        </Modal>
    );
};

// ============================================================================
// 补全缺失组件：DatacenterModal (机房编辑)
// ============================================================================
const DatacenterModal = ({ dc, onClose, onSave }) => {
    const [formData, setFormData] = useState({ name: '', location: '', ...dc });
    return (
        <Modal isOpen={true} onClose={onClose} title={dc ? '编辑机房信息' : '新建机房区域'}>
            <div className="space-y-4">
                <FormInput label="机房名称" value={formData.name} onChange={e => setFormData({...formData, name: e.target.value})} required />
                <FormInput label="物理位置描述" value={formData.location} onChange={e => setFormData({...formData, location: e.target.value})} />
                <div className="flex justify-end pt-4">
                    <button onClick={() => onSave(formData)} className="px-6 py-2 bg-blue-600 text-white rounded font-bold shadow-lg hover:bg-blue-700">确认保存</button>
                </div>
            </div>
        </Modal>
    );
};

// ============================================================================
// 补全缺失组件：IPPoolGrid (IP地址池视图)
// ============================================================================
const IPPoolGrid = ({ subnetId, ips, onIPClick }) => {
    const gridItems = useMemo(() => {
        const items = [];
        for (let i = 1; i <= 254; i++) {
            const suffix = `.${i}`;
            const ipData = ips.find(ip => ip.ip_address.endsWith(suffix) && ip.subnet === subnetId);
            items.push({ suffix, data: ipData, i });
        }
        return items;
    }, [ips, subnetId]);

    return (
        <div className="p-6 grid grid-cols-8 sm:grid-cols-10 md:grid-cols-12 lg:grid-cols-16 gap-2">
            {gridItems.map(({ i, data }) => {
                 let bgColor = 'bg-slate-50 border-slate-200 text-slate-400';
                 if (data) {
                     if (data.status === 'online' || data.status === 'active') bgColor = 'bg-green-100 border-green-300 text-green-700 font-bold';
                     else if (data.status === 'reserved') bgColor = 'bg-blue-100 border-blue-300 text-blue-700';
                     else if (data.status === 'rogue') bgColor = 'bg-red-100 border-red-300 text-red-700';
                     else bgColor = 'bg-slate-100 border-slate-300 text-slate-500';
                 }

                 return (
                    <div 
                        key={i} 
                        onClick={() => onIPClick(data || { ip: `192.168.1.${i}`, status: 'free' })}
                        className={`aspect-square rounded border flex items-center justify-center text-xs cursor-pointer hover:scale-110 transition-transform shadow-sm ${bgColor}`}
                        title={data ? `${data.ip_address}\n${data.device_name || '未知设备'}` : `可用 IP`}
                    >
                        {i}
                    </div>
                 )
            })}
        </div>
    );
};


// ============================================================================
// 0. 独立组件：机柜排位图 (UI显示专用 - 顶部对齐/向下延伸版)
// ============================================================================
const RackElevation = ({ rack, devices, onSelect, onEdit }) => {
  const totalU = safeInt(rack.height, 42);
  const slots = [];
  const renderedUs = new Set(); 

  for (let u = totalU; u >= 1; u--) {
      if (renderedUs.has(u)) continue;

      const device = devices.find(d => {
          const top = safeInt(d.position);
          return top === u;
      });

      if (device) {
          const top = safeInt(device.position);
          const h = Math.max(1, safeInt(device.u_height, 1));
          const bottom = top - h + 1;

          for (let i = 0; i < h; i++) {
              const occupiedU = top - i;
              if (occupiedU >= 1) renderedUs.add(occupiedU);
          }

          const pixelHeight = (h * 32) + (h - 1);
          const powerUsage = safeInt(device.power_usage);
          const isHighPower = powerUsage > 500;
          const powerColorClass = isHighPower ? "text-yellow-200 font-extrabold" : "text-slate-300 opacity-80";

          slots.push(
              <div key={u}
                   className="w-full bg-blue-600 border border-white text-white text-sm font-bold flex flex-col justify-center items-center cursor-pointer hover:bg-blue-500 transition-colors shadow-sm relative group overflow-hidden z-10"
                   style={{ height: `${pixelHeight}px` }}
                   onClick={(e) => { e.stopPropagation(); onSelect(rack); onEdit(device); }}
                   title={`${device.name}\n位置: ${bottom}-${top}U (高${h}U)\nIP: ${device.mgmt_ip}`}
              >
                  <span className="truncate px-1 w-full text-center text-xs">{device.name}</span>
                  <span className={`text-[10px] ${powerColorClass}`}>{powerUsage > 0 ? `${powerUsage}W` : ''}</span>
              </div>
          );
      } else {
          const deviceOverlapping = devices.find(d => {
              const top = safeInt(d.position);
              const h = safeInt(d.u_height, 1);
              const bottom = top - h + 1;
              return u <= top && u >= bottom && top > totalU;
          });

          if (deviceOverlapping && !renderedUs.has(u)) {
               const top = safeInt(deviceOverlapping.position);
               const h = safeInt(deviceOverlapping.u_height, 1);
               const bottom = top - h + 1;
               const visibleTop = u;
               const visibleBottom = Math.max(bottom, 1);
               const visibleHeight = visibleTop - visibleBottom + 1;

               for (let i = 0; i < visibleHeight; i++) renderedUs.add(visibleTop - i);

               const pixelHeight = (visibleHeight * 32) + (visibleHeight - 1);

               slots.push(
                  <div key={u}
                       className="w-full bg-blue-600 border border-white text-white text-sm font-bold flex flex-col justify-center items-center cursor-pointer hover:bg-blue-500 transition-colors shadow-sm relative group overflow-hidden z-10"
                       style={{ height: `${pixelHeight}px` }}
                       onClick={(e) => { e.stopPropagation(); onSelect(rack); onEdit(deviceOverlapping); }}
                       title={`${deviceOverlapping.name} (截断显示)\n真实位置: ${bottom}-${top}U`}
                  >
                      <span className="absolute top-0 right-0 bg-red-500 text-[8px] px-1 text-white">Top截断</span>
                      <span className="truncate px-1 w-full text-center text-xs">{deviceOverlapping.name}</span>
                  </div>
               );
          } else {
              slots.push(
                  <div key={u} className="w-full h-[32px] border-b border-slate-300 bg-white flex items-center justify-center text-[10px] text-slate-300 hover:bg-blue-50 cursor-pointer"
                       onClick={(e) => { e.stopPropagation(); onSelect(rack); onEdit({ position: u, u_height: 1, device_type: 'server', name: '' }); }}
                  >
                      {u % 5 === 0 ? u : ''}
                  </div>
              );
          }
      }
  }
  return <div className="flex-1 bg-slate-900 p-1 space-y-[1px] relative min-h-[600px]">{slots}</div>;
};

// ============================================================================
// 0.1 独立组件：机柜详情侧边栏 (顶部对齐版)
// ============================================================================
const RackDetailSidebar = ({ selectedRack, rackDevices, onClose, onEdit, getRackCalculatedPower }) => {
    if (!selectedRack) return null;

    const stats = getRackCalculatedPower(selectedRack.id);
    const totalU = safeInt(selectedRack.height, 42);
    const units = [];
    const renderedUs = new Set();

    const currentDevices = rackDevices.filter(d => d.rack === selectedRack.id);

    for (let u = totalU; u >= 1; u--) {
        if (renderedUs.has(u)) continue;
        const device = currentDevices.find(d => safeInt(d.position) === u);

        if (device) {
            const top = safeInt(device.position);
            const h = Math.max(1, safeInt(device.u_height, 1));
            const bottom = top - h + 1;

            for (let i = 0; i < h; i++) {
                if (top - i >= 1) renderedUs.add(top - i);
            }

            const pixelHeight = (h * 34) + (h - 1);
            const uLabel = h > 1 ? `${bottom}-${top}` : `${top}`;

            units.push(
                <div key={u} onClick={() => onEdit(device)} className="w-full relative group cursor-pointer transition-all hover:z-10" style={{ height: `${pixelHeight}px` }}>
                    <div className="absolute inset-0 bg-white border border-slate-300 rounded-sm shadow-sm flex flex-row overflow-hidden hover:ring-2 hover:ring-blue-400 hover:shadow-md transition-all">
                        <div className={`w-10 h-full flex-shrink-0 flex items-center justify-center text-[10px] font-bold text-white ${device.status === 'active' ? 'bg-emerald-500' : 'bg-amber-500'}`} title={`位置: ${uLabel}U`}>
                            {uLabel}
                        </div>
                        <div className="flex-1 flex flex-col justify-center px-3 py-0.5 min-w-0">
                            <div className="flex items-center justify-between">
                                <span className="font-bold text-slate-800 text-sm truncate mr-2 flex items-center">
                                    {device.device_type === 'server' ? <Server className="w-3.5 h-3.5 mr-1.5 text-slate-400"/> : <HardDrive className="w-3.5 h-3.5 mr-1.5 text-slate-400"/>}
                                    {device.name}
                                </span>
                            </div>
                            <div className="flex space-x-3 mt-1">
                                <span className="text-[10px] text-slate-500 flex items-center bg-slate-100 px-1.5 py-0.5 rounded"><Zap className="w-3 h-3 mr-1 text-slate-400"/>{device.power_usage}W</span>
                                <span className="text-[10px] text-slate-400 flex items-center">{device.mgmt_ip}</span>
                            </div>
                        </div>
                    </div>
                </div>
            );
        } else {
             const deviceOverlapping = currentDevices.find(d => {
                const top = safeInt(d.position);
                const h = safeInt(d.u_height, 1);
                const bottom = top - h + 1;
                return u <= top && u >= bottom && top > totalU;
            });

            if (deviceOverlapping && !renderedUs.has(u)) {
                const top = safeInt(deviceOverlapping.position);
                const h = safeInt(deviceOverlapping.u_height, 1);
                const bottom = top - h + 1;
                const visibleHeight = u - Math.max(bottom, 1) + 1;

                for(let i=0; i<visibleHeight; i++) renderedUs.add(u-i);

                const pixelHeight = (visibleHeight * 34) + (visibleHeight - 1);
                units.push(
                    <div key={u} onClick={() => onEdit(deviceOverlapping)} className="w-full relative group cursor-pointer transition-all hover:z-10" style={{ height: `${pixelHeight}px` }}>
                        <div className="absolute inset-0 bg-white border border-red-300 rounded-sm shadow-sm flex flex-row overflow-hidden">
                             <div className="w-10 h-full bg-red-500 flex items-center justify-center text-white text-[9px]">截断</div>
                             <div className="flex-1 flex items-center px-3 text-red-500 text-xs">{deviceOverlapping.name} (Top: {top})</div>
                        </div>
                    </div>
                );
            } else if (!renderedUs.has(u)) {
                units.push(
                    <div key={u} onClick={() => onEdit({ position: u, u_height: 1, device_type: 'server', name: '', power_usage: 0, typical_power: 0 })} className="w-full border-b border-slate-200/50 flex items-center justify-between px-3 hover:bg-blue-50/50 cursor-pointer group transition-colors relative" style={{ height: `34px` }}>
                        <span className="text-[10px] text-slate-300 font-mono select-none w-6 text-center">{u}</span>
                        <div className="flex-1 border-2 border-dashed border-transparent group-hover:border-blue-200 rounded mx-2 h-6 flex items-center justify-center">
                            <Plus className="w-3 h-3 text-blue-300 opacity-0 group-hover:opacity-100" />
                        </div>
                        <span className="text-[10px] text-slate-300 font-mono select-none w-6 text-center">{u}</span>
                    </div>
                );
            }
        }
    }

    return (
        <>
            <div className="fixed inset-0 bg-slate-900/20 z-40 backdrop-blur-sm transition-opacity" onClick={onClose}></div>
            <div className="fixed top-0 right-0 h-full w-[500px] bg-white shadow-2xl z-50 flex flex-col animate-in slide-in-from-right duration-300 border-l border-slate-200">
                <div className="p-5 border-b border-slate-100 flex justify-between items-center bg-white shadow-sm z-10">
                    <div>
                        <h3 className="font-extrabold text-xl text-slate-800 flex items-center gap-2"><Server className="w-5 h-5 text-blue-600"/> {selectedRack.name}</h3>
                        <p className="text-xs text-slate-500 font-mono mt-1 ml-7">{selectedRack.code} • {totalU}U 标准机柜</p>
                    </div>
                    <button onClick={onClose} className="p-2 hover:bg-slate-100 rounded-full text-slate-400 hover:text-slate-700 transition-colors"><X className="w-5 h-5"/></button>
                </div>

                <div className="grid grid-cols-3 gap-0 border-b border-slate-100 bg-slate-50/50">
                    <div className="p-4 text-center border-r border-slate-100">
                        <div className="text-[10px] text-slate-400 uppercase font-bold tracking-wider mb-1">额定总负荷</div>
                        <div className="text-lg font-black text-slate-700">{stats.rated_sum}<span className="text-xs font-normal text-slate-400 ml-0.5">W</span></div>
                    </div>
                    <div className="p-4 text-center border-r border-slate-100">
                        <div className="text-[10px] text-blue-500 uppercase font-bold tracking-wider mb-1">典型运行</div>
                        <div className="text-lg font-black text-blue-600">{stats.typical_sum}<span className="text-xs font-normal text-blue-300 ml-0.5">W</span></div>
                    </div>
                    <div className="p-4 text-center">
                        <div className="text-[10px] text-emerald-500 uppercase font-bold tracking-wider mb-1">PDU 实测</div>
                        <div className="text-lg font-black text-emerald-600">{(selectedRack.pdu_a_power||0)+(selectedRack.pdu_b_power||0)}<span className="text-xs font-normal text-emerald-300 ml-0.5">W</span></div>
                    </div>
                </div>

                <div className="flex-1 overflow-y-auto p-6 bg-slate-100/50 custom-scrollbar">
                    <div className="w-full bg-white p-1 rounded-lg border border-slate-200 shadow-sm">
                        <div className="h-4 bg-slate-200 border-b border-slate-300 rounded-t-md mb-0.5 flex justify-center items-center">
                            <div className="w-16 h-1 bg-slate-300 rounded-full"></div>
                        </div>
                        <div className="bg-slate-100 border-x border-slate-200 space-y-[1px] relative">
                            {units}
                        </div>
                        <div className="h-6 bg-slate-200 border-t border-slate-300 rounded-b-md mt-0.5 flex justify-between px-4 items-center">
                            <div className="w-2 h-2 rounded-full bg-slate-400"></div>
                            <div className="w-2 h-2 rounded-full bg-slate-400"></div>
                        </div>
                    </div>
                </div>

                <div className="p-5 border-t border-slate-100 bg-white z-10">
                    <button onClick={() => onEdit({ position: 1, u_height: 1, device_type: 'server', name: '' })} className="w-full py-3.5 bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-bold text-sm shadow-lg shadow-blue-200 transition-all flex items-center justify-center hover:-translate-y-0.5 active:translate-y-0">
                        <Plus className="w-4 h-4 mr-2" /> 在此机柜上架新设备
                    </button>
                </div>
            </div>
        </>
    );
};

// ============================================================================
// 0.2 全局错误边界
// ============================================================================
class ErrorBoundary extends React.Component {
  constructor(props) {
    super(props);
    this.state = { hasError: false, error: null, errorInfo: null };
  }

  static getDerivedStateFromError(error) {
    return { hasError: true, error };
  }

  componentDidCatch(error, errorInfo) {
    console.error("Critical Error caught by boundary:", error, errorInfo);
    this.setState({ errorInfo });
  }

  handleClearCacheAndReload = () => {
    localStorage.clear();
    window.location.reload();
  };

  render() {
    if (this.state.hasError) {
      return (
        <div className="min-h-screen flex items-center justify-center bg-slate-50 p-4 font-sans">
          <div className="bg-white p-6 rounded-xl shadow-2xl max-w-2xl w-full border border-red-200">
            <div className="flex items-center gap-3 mb-4 text-red-600 border-b border-red-100 pb-3">
              <AlertTriangle size={32} />
              <h2 className="text-xl font-bold">系统发生运行时错误 (Runtime Error)</h2>
            </div>

            <p className="text-sm text-slate-600 mb-4">React 渲染过程中遇到了未捕获的异常。这通常是由于本地缓存数据结构不匹配或网络请求返回了非预期的数据。</p>

            <div className="bg-slate-900 text-red-300 p-4 rounded-lg text-xs font-mono overflow-auto max-h-60 mb-6 shadow-inner">
              <p className="font-bold border-b border-red-900/50 pb-2 mb-2">{this.state.error?.toString()}</p>
              <pre className="whitespace-pre-wrap opacity-70">{this.state.errorInfo?.componentStack}</pre>
            </div>

            <div className="flex gap-4">
               <button
                 onClick={this.handleClearCacheAndReload}
                 className="flex-1 px-4 py-3 bg-red-600 hover:bg-red-700 text-white rounded-lg font-bold transition-all shadow-md active:scale-95 flex items-center justify-center"
               >
                 <Trash2 size={16} className="mr-2"/> 清除缓存并重启 (推荐)
               </button>
               <button
                 onClick={() => window.location.reload()}
                 className="flex-1 px-4 py-3 bg-white border border-slate-300 text-slate-700 hover:bg-slate-50 rounded-lg font-bold transition-all active:scale-95"
               >
                 仅刷新页面
               </button>
            </div>
          </div>
        </div>
      );
    }
    return this.props.children;
  }
}

